package Sorting;

//1. SELECTION SORT
//Time Complexity: O(n²)
//============================================================

class SelectionSort {
 public static void selectionSort(int[] arr) {
     int n = arr.length;
     for (int i = 0; i < n - 1; i++) {
         int minIdx = i;
         for (int j = i + 1; j < n; j++) {
             if (arr[j] < arr[minIdx]) {
                 minIdx = j;
             }
         }
         // Swap
         int temp = arr[i];
         arr[i] = arr[minIdx];
         arr[minIdx] = temp;
     }
 }
 
 public static void main(String[] args) {
     System.out.println("\n===== SELECTION SORT DEMO =====");
     int[] arr = {64, 25, 12, 22, 11};
     System.out.print("Original array: ");
     for (int num : arr) System.out.print(num + " ");
     
     selectionSort(arr);
     System.out.print("\nSorted array:   ");
     for (int num : arr) System.out.print(num + " ");
     System.out.println();
 }
}